# Copia questo file in ".env.local" e riempi i valori. Non committare .env.local.

# --- Supabase (Project Settings -> API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (Claude API) — solo lato server, mai esposta al browser ---
ANTHROPIC_API_KEY=

# --- Stripe (le aggiungi quando attivi i pagamenti) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Email (Resend) — opzionale all'inizio ---
RESEND_API_KEY=
